<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- The app does not make any network requests; this config ensures
         cleartext traffic is disabled for security best practices. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
