<?xml version="1.0" encoding="utf-8"?>
<!-- The app uses a dark-first design so day and night themes are identical.
     This file satisfies the DayNight resolver; Android will use it when the
     system is in dark mode. -->
<resources>
    <style name="Theme.WiFiVisualizerAR" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorOnSecondary">@color/surface_dark_1</item>
        <item name="colorSurface">@color/surface_dark_1</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_dark_2</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:colorBackground">@color/surface_dark_1</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/color_error</item>
        <item name="colorOnError">@android:color/white</item>
        <item name="android:statusBarColor">@color/surface_dark_2</item>
        <item name="android:navigationBarColor">@color/surface_dark_2</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/surface_dark_1</item>
        <item name="colorControlActivated">@color/brand_accent</item>
        <item name="colorControlHighlight">@color/brand_accent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
</resources>
