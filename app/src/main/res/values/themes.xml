<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base application theme.
        WiFi Visualizer AR uses a dark-first design with a blue/slate palette.
        We derive from Material3 DayNight so system dark mode is automatically honoured.
    -->
    <style name="Theme.WiFiVisualizerAR" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary brand colour -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>

        <!-- Secondary / Accent -->
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorOnSecondary">@color/surface_dark_1</item>

        <!-- Surface -->
        <item name="colorSurface">@color/surface_dark_1</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_dark_2</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/surface_dark_1</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Error -->
        <item name="colorError">@color/color_error</item>
        <item name="colorOnError">@android:color/white</item>

        <!-- Status bar / navigation bar -->
        <item name="android:statusBarColor">@color/surface_dark_2</item>
        <item name="android:navigationBarColor">@color/surface_dark_2</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Window flags -->
        <item name="android:windowBackground">@color/surface_dark_1</item>
        <item name="android:windowAnimationStyle">@style/Animation.AppCompat.Dialog</item>

        <!-- Material card defaults -->
        <item name="materialCardViewStyle">@style/Widget.WiFiVisualizer.CardView</item>

        <!-- ProgressBar tint -->
        <item name="colorControlActivated">@color/brand_accent</item>
        <item name="colorControlHighlight">@color/brand_accent</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Custom MaterialCardView default -->
    <style name="Widget.WiFiVisualizer.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_dark_2</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!--
        Splash screen theme – shown while the app cold-starts.
        The Activity transitions immediately to Theme.WiFiVisualizerAR.
    -->
    <style name="Theme.WiFiVisualizerAR.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/surface_dark_1</item>
        <item name="android:navigationBarColor">@color/surface_dark_1</item>
        <item name="android:windowBackground">@color/surface_dark_1</item>
    </style>

</resources>
